    <ArcGisDotNetDir Condition=" '$(ArcGisDotNetDir)' == '' ">D:\Program Files (x86)\ArcGIS\DeveloperKit10.2\DotNet</ArcGisDotNetDir>
  </PropertyGroup>
</Project>
